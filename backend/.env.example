# ============================================================================
# DEGAS ATTENDANCE SYSTEM - Backend Environment Variables
# Example file showing all available configuration options
# ============================================================================
# Copy this file to .env and fill in with your own values
# For local development, SQLite is easier. For production, use PostgreSQL
# ============================================================================

# ============================================================================
# CRITICAL REQUIRED VARIABLES (App will fail to start without these)
# ============================================================================

# Node.js environment: 'development' or 'production'
NODE_ENV=development

# Server port: 3001 for local, 10000 for Render
PORT=3001

# Database type: 'sqlite' (file-based, easy local dev) or 'postgresql' (cloud)
DATABASE_TYPE=sqlite

# JWT Secret for authentication - use strong, unique values
# Generate: openssl rand -base64 32
JWT_SECRET=change-this-to-a-strong-secret-in-production

# QR Code signing secret - for secure QR token generation
# Generate: openssl rand -base64 32
QR_SECRET=change-this-to-a-strong-qr-secret-in-production

# ============================================================================
# STRONGLY RECOMMENDED PRODUCTION VARIABLES
# ============================================================================

# Core user JWT secret for dual-token authentication
CORE_USER_JWT_SECRET=change-this-to-a-strong-core-user-secret-in-production

# Core user token expiration time
CORE_USER_JWT_EXPIRES_IN=7d

# Frontend URL for CORS - must match your frontend domain
FRONTEND_URL=http://localhost:5173

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# For SQLite (local/Render with persistent disk):
DATABASE_PATH=./data/degas.db

# For PostgreSQL (production, cloud-hosted):
# Use one of these service providers:
# - Neon: https://neon.tech (free tier available)
# - AWS RDS: https://aws.amazon.com/rds/
# - Google Cloud SQL: https://cloud.google.com/sql/
# Example: postgresql://user:password@host.region.provider.tech:5432/dbname
DATABASE_URL=postgresql://username:password@localhost:5432/degas_cs

# ============================================================================
# FILE UPLOAD CONFIGURATION
# ============================================================================

# Directory for file uploads (relative path for local, absolute for Render)
# Local: ./uploads
# Render: /opt/render/project/src/backend/uploads
UPLOAD_DIR=uploads

# Maximum file size in bytes (10485760 = 10 MB)
MAX_FILE_SIZE=10485760

# ============================================================================
# OPTIONAL: CLOUDINARY IMAGE STORAGE
# ============================================================================
# For persistent image storage that survives redeploys
# Free tier: 25 GB storage, 25 GB bandwidth/month
# Sign up: https://cloudinary.com/users/register/free
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# ============================================================================
# RATE LIMITING
# ============================================================================

# Rate limit window in milliseconds (900000 = 15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# Maximum requests per IP per window
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# OPTIONAL: EMAIL SERVICE (RESEND)
# ============================================================================
# For sending email notifications
# Free tier: 3,000 emails/month, 100 emails/day
# Sign up: https://resend.com
# RESEND_API_KEY=re_your_actual_api_key_here
# EMAIL_FROM=noreply@yourdomain.com

# ============================================================================
# DEVELOPMENT ONLY - NEVER ENABLE IN PRODUCTION
# ============================================================================

# Mock mode disables real database and uses fake test data
# This is ONLY for local development testing
# ALWAYS set to false in production
DEV_MOCK=false

# ============================================================================
# DEPLOYMENT QUICK REFERENCE
# ============================================================================
# 
# LOCAL DEVELOPMENT (SQLite):
# NODE_ENV=development
# PORT=3001
# DATABASE_TYPE=sqlite
# FRONTEND_URL=http://localhost:5173
#
# RENDER PRODUCTION (SQLite + Persistent Disk):
# NODE_ENV=production
# PORT=10000 (or use PORT assigned by Render)
# DATABASE_TYPE=sqlite
# FRONTEND_URL=https://your-frontend.onrender.com
# UPLOAD_DIR=/opt/render/project/src/backend/uploads
#
# CLOUD POSTGRES PRODUCTION:
# NODE_ENV=production
# DATABASE_TYPE=postgresql
# DATABASE_URL=postgresql://... (from Neon, AWS, Google Cloud, etc)
# FRONTEND_URL=https://your-frontend.onrender.com
#
# ============================================================================
