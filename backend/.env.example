# Database Configuration
DATABASE_TYPE=sqlite
# For SQLite (local development)
DATABASE_PATH=./data/degas.db
# For PostgreSQL (production)
DATABASE_URL=postgresql://username:password@localhost:5432/degas_cs

# JWT Secrets
JWT_SECRET=your-super-secret-jwt-key-here
CORE_USER_JWT_SECRET=your-core-user-jwt-secret-here
CORE_USER_JWT_EXPIRES_IN=7d
QR_SECRET=your-super-secret-qr-signing-key-here

# Server Configuration
PORT=3001
NODE_ENV=development

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# CORS
FRONTEND_URL=http://localhost:5173

# Email Configuration (Resend) - Optional
# Get your API key from: https://resend.com/api-keys
# Free tier: 3,000 emails/month, 100 emails/day
RESEND_API_KEY=re_123456789_YourResendAPIKeyHere
EMAIL_FROM=onboarding@resend.dev

# Cloudinary (Optional - for persistent image storage)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Mock Mode (ONLY for development - NEVER in production)
DEV_MOCK=false
