# ============================================================================
# DEGAS ATTENDANCE SYSTEM - Frontend Environment Variables
# Example file showing available Vite configuration
# ============================================================================
# Copy to .env and update values for your environment
# Frontend variables must be prefixed with VITE_ to be exposed to the browser
# ============================================================================

# ============================================================================
# REQUIRED: Backend API URL
# ============================================================================

# For local development (backend running on localhost:3001):
VITE_API_URL=http://localhost:3001/api

# For production (Render backend service):
# VITE_API_URL=https://degas-cs-backend.onrender.com/api

# ============================================================================
# NOTES
# ============================================================================
# - Frontend is a static site, so NO sensitive secrets here
# - All environment variables are exposed to the browser
# - Only put public, non-sensitive configuration values
# - Production URL is set in Render's Environment Variables panel
# ============================================================================
